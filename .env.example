# ================================
# Docker镜像配置 - Docker Hub 示例
# 不用docker部署可以忽略
# ================================
# Docker Hub 配置 (留空或使用 docker.io)
DOCKER_REGISTRY=https://hub.docker.com/
DOCKER_NAMESPACE=your-namespace
IMAGE_VERSION=latest

# ================================
# 服务端口配置,不用docker部署可以忽略
# ================================
# 前端服务端口
FRONTEND_PORT=80
# 后端服务端口
BACKEND_PORT=8000
# 容器内部访问MySQL的端口（Docker网络内部通信）
DB_INTERNAL_PORT=3306

# ================================
# Django配置
# ================================
# Django密钥（生产环境请使用强密钥）
SECRET_KEY=your-secret-key-here-change-in-production
# JWT签名密钥（建议与 SECRET_KEY 分开，生产环境必须独立配置）
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SIGNING_KEY=
# 字段级加密密钥（用于 AI 模型 / 服务的 api_key 落库加密）
# 留空则基于 SECRET_KEY 派生（仅开发用）。
# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=
# 调试模式（生产环境请设为False）
DEBUG=True
# 允许的主机列表（生产环境必须显式列出域名，绝不能用通配符 *；
# settings.py 在 DEBUG=False 时会强制校验并拒绝启动）
ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
# 允许的跨域来源（多个用逗号分隔；生产环境必须显式配置）
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# ================================
# 数据库配置
# ================================
# 数据库名称
DB_NAME=testhub
# 数据库用户名
DB_USER=root
# 数据库密码
DB_PASSWORD=your-database-password
# MySQL数据库端口号
DB_PORT=3306

# ================================
# Redis配置（可选,用于APP自动化）
# ================================
REDIS_URL=redis://127.0.0.1:6379/0

# ================================
# Celery 任务结果存储
# ================================
# 默认与 broker 共用 Redis（性能最佳，但 Admin 不可见）。
# 设为 ``django-db`` 可改用 DB 存储 + Django Admin 查看 TaskResult。
# CELERY_RESULT_BACKEND=django-db
# 结果保留时长（秒），默认 24h
# CELERY_RESULT_EXPIRES=86400

# ================================
# 出站请求 SSRF 防护
# ================================
# 默认阻止业务侧 HTTP 工具调用私有 / loopback / 保留地址。
# 仅当确实需要访问内网（例如本地 webhook 测试）时改为 True。
ALLOW_INTERNAL_OUTBOUND_URLS=False

# ================================
# 上传体积上限（字节）
# ================================
# 默认 25MB。OCR / 大型需求文档需要时调高。
DATA_UPLOAD_MAX_MEMORY_SIZE=26214400
FILE_UPLOAD_MAX_MEMORY_SIZE=26214400
MAX_UPLOAD_FILE_SIZE=26214400

# ================================
# JWT refresh token 存储
# ================================
# 登录时后端会把 refresh token 写入 httpOnly cookie，前端不再持有。
# Cookie 名称 / 路径 / SameSite 可按部署需要覆盖。
JWT_REFRESH_COOKIE_NAME=th_refresh
JWT_REFRESH_COOKIE_PATH=/api/auth/
JWT_REFRESH_COOKIE_SAMESITE=Lax
# 生产强制 Secure；开发 (DEBUG=True) 默认 False。
JWT_REFRESH_COOKIE_SECURE=False

# ================================
# 邮件配置（可选,用于定时任务通知）
# ================================
EMAIL_HOST=smtp.163.com
EMAIL_PORT=465
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_email_password
DEFAULT_FROM_EMAIL=your_email@gmail.com

# 教程截图/演示脚本使用的后台登录账号
TESTHUB_TUTORIAL_USERNAME=your_admin_username
TESTHUB_TUTORIAL_PASSWORD=your_admin_password

# 日志配置
# LOG_LEVEL=INFO
# LOG_FILE=/app/logs/app.log

# 本地化配置
# 语言: 'en-us' (英语), 'zh-hans' (简体中文), 'ja' (日语), 'ko' (韩语) 等
# 时区: 参考 https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
LANGUAGE_CODE=zh-hans
TIME_ZONE=Asia/Shanghai

# ================================
# 生产环境注意事项
# ================================
# 1. 请务必修改SECRET_KEY为强密钥
# 2. 设置DEBUG=False
# 3. 在ALLOWED_HOSTS中指定具体域名，不要使用*
# 4. 在CORS_ALLOWED_ORIGINS中指定具体的前端域名
# 5. 使用环境变量管理敏感信息，不要提交到版本控制
# 6. 确保数据库密码足够强壮
# 7. 邮件配置使用真实的SMTP服务
